page {
  background: #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
}

.page {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #475569;
  line-height: 1.6;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.label {
  color: #334155;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  display: block;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  margin-bottom: 20rpx;
}

.picker-value {
  display: block;
}

.button-primary,
.button-secondary,
.button-danger {
  border-radius: 16rpx;
  padding: 10rpx 0;
  font-size: 28rpx;
  margin-top: 12rpx;
}

.button-primary {
  background: #0f766e;
  color: #ffffff;
}

.button-secondary {
  background: #e2e8f0;
  color: #0f172a;
}

.button-danger {
  background: #dc2626;
  color: #ffffff;
}

.nav-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nav-link {
  padding: 14rpx 18rpx;
  background: #dbeafe;
  color: #1d4ed8;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.item-meta {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
}

.empty {
  color: #64748b;
  text-align: center;
  padding: 40rpx 0;
}

.result-box {
  background: #ecfeff;
  border: 2rpx solid #99f6e4;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.inline-row {
  display: flex;
  gap: 16rpx;
}

.inline-col {
  flex: 1;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.switch-row:last-child {
  border-bottom: none;
}

<view class="page">
  <view class="nav-row">
    <view class="nav-link" bindtap="goToReservations">我的预约</view>
    <view class="nav-link" bindtap="goToCheckin">签到</view>
    <view class="nav-link" bindtap="goToAssistant">助手</view>
    <view class="nav-link" bindtap="logout">退出</view>
  </view>

  <view class="card" wx:if="{{user}}">
    <view class="section-title">{{user.name}}</view>
    <view class="item-meta">学号：{{user.student_no}}</view>
    <view class="item-meta" wx:if="{{user.department}}">院系：{{user.department.name}}</view>
    <view class="item-meta">最近刷新：{{lastRefreshed}}</view>
  </view>

  <view class="card">
    <view class="section-title">可见自习室</view>
    <view wx:if="{{loading}}" class="empty">加载中...</view>
    <view wx:elif="{{!rooms.length}}" class="empty">当前没有可访问自习室</view>
    <view wx:for="{{rooms}}" wx:key="id" class="card">
      <view class="item-title">{{item.name}}</view>
      <view class="item-meta">位置：{{item.location}}</view>
      <view class="item-meta">开放：{{item.open_time}} - {{item.close_time}}</view>
      <view class="item-meta">范围：{{item.department_scope}}</view>
      <button
        class="button-primary"
        data-room-id="{{item.id}}"
        data-room-name="{{item.name}}"
        bindtap="goToRoom"
      >
        查看座位并预约
      </button>
    </view>
  </view>
</view>

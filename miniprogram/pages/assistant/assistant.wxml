<view class="page">
  <view class="nav-row">
    <view class="nav-link" bindtap="goToRooms">自习室</view>
    <view class="nav-link" bindtap="goToReservations">我的预约</view>
    <view class="nav-link" bindtap="goToCheckin">签到</view>
  </view>

  <view class="card">
    <view class="title">规则助手</view>
    <view class="subtitle">支持“今天晚上还有空座吗”“帮我找靠窗的座位”“我今天定了哪里的座位”等查询。</view>
  </view>

  <view class="card">
    <textarea
      class="textarea"
      auto-height
      placeholder="请输入自然语言问题"
      value="{{message}}"
      bindinput="onMessageInput"
    />
    <button class="button-primary" loading="{{loading}}" bindtap="submitQuery">发送查询</button>
  </view>

  <view class="card" wx:if="{{resultView}}">
    <view class="section-title">{{resultView.title}}</view>
    <view wx:if="{{resultView.kind === 'error'}}" class="assistant-state error-state">
      <view>{{resultView.message}}</view>
    </view>
    <view wx:elif="{{resultView.kind === 'empty'}}" class="assistant-state empty-state">
      <view>{{resultView.message}}</view>
    </view>
    <view wx:else class="assistant-list">
      <view wx:for="{{resultView.items}}" wx:key="id" class="assistant-result-card">
        <view class="item-title">{{item.title}}</view>
        <view class="item-meta">{{item.subtitle}}</view>
        <view class="item-meta">{{item.meta}}</view>
      </view>
    </view>
  </view>
</view>

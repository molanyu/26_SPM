<view class="page">
  <view class="nav-row">
    <view class="nav-link" bindtap="goToRooms">自习室</view>
    <view class="nav-link" bindtap="goToReservations">我的预约</view>
    <view class="nav-link" bindtap="goToAssistant">助手</view>
  </view>

  <view class="card">
    <view class="section-title">选择当前预约</view>
    <view wx:if="{{loading}}" class="empty">加载中...</view>
    <view wx:elif="{{!reservations.length}}" class="empty">当前没有可签到预约</view>
    <picker wx:else mode="selector" range="{{reservations}}" range-key="reservation_id" bindchange="onReservationChange">
      <view class="picker-value">当前预约：{{selectedReservationId || '请选择'}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="section-title">动态码签到</view>
    <input class="input" placeholder="请输入教室动态码" value="{{code}}" bindinput="onCodeInput" />
    <button class="button-primary" bindtap="submitCodeCheckin">提交动态码签到</button>
  </view>

  <view class="card">
    <view class="section-title">二维码签到</view>
    <view class="subtitle">点击扫码，自动提取 token 并提交二维码签到。</view>
    <button class="button-secondary" bindtap="scanQrCode">扫码签到</button>
  </view>
</view>

# Local runtime
APP_NAME=SPM Study Room API
JWT_SECRET_KEY=spm-dev-secret
DATABASE_URL=postgresql+psycopg://spm:spm@127.0.0.1:5432/spm
POSTGRES_REGRESSION_URL=postgresql+psycopg://spm:spm@127.0.0.1:5432/spm
DATABASE_AUTO_CREATE=false

# Docker Compose runtime
DOCKER_DATABASE_URL=postgresql+psycopg://spm:spm@db:5432/spm
POSTGRES_DB=spm
POSTGRES_USER=spm
POSTGRES_PASSWORD=spm
POSTGRES_PORT=5432
APP_PORT=8000

# Controlled bootstrap
IDENTITY_BOOTSTRAP_ENABLED=false
IDENTITY_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
IDENTITY_BOOTSTRAP_ADMIN_NAME=System Admin
IDENTITY_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Notification channel
NOTIFICATION_DEFAULT_CHANNEL=mock
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

# Background task scheduler
TASK_SCHEDULER_ENABLED=true
TASK_SCHEDULER_INTERVAL_SECONDS=60
